# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — Open-World Portfolio
# Copy this file to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="Open World Portfolio"
VITE_APP_VERSION="0.1.0"

# ── GitHub Integration (future) ─────────────────────────────────────────────
# Personal access token for live GitHub data sync
VITE_GITHUB_TOKEN=your_github_personal_access_token_here
VITE_GITHUB_USERNAME=your_github_username

# ── AI Assistant (future) ────────────────────────────────────────────────────
# API endpoint for the in-world AI assistant (FastAPI backend)
VITE_AI_ASSISTANT_URL=http://localhost:8000

# ── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_PHYSICS=true
VITE_ENABLE_AUDIO=true
VITE_ENABLE_AI_ASSISTANT=false
VITE_ENABLE_MULTIPLAYER=false

# ── Performance ──────────────────────────────────────────────────────────────
# Force a performance tier: "low" | "medium" | "high" | "auto"
VITE_PERFORMANCE_TIER=auto
